# --- System & Identity & Various Configuration ---
# User/Group IDs, API token for Let's Encrypt DNS challenges and Busybox version tag
PUID=1000
GUID=1000
SOCKET_GID=987
GANDIV5_PERSONAL_ACCESS_TOKEN=your_token_here
BUSYBOX_VERSION_TAG=1.36

# --- DDNS Updater ---
# Version tag
DDNS_UPDATER_VERSION_TAG=latest

# --- Database (MariaDB/MySQL) ---
# Version tag and credentials for the internal database network
MYSQL_VERSION_TAG=11.4
MYSQL_ROOT_PASSWORD=super_secure_root_pass

# --- Traefik Reverse Proxy ---
# Traefik version tag, dashboard configuration and Let's Encrypt registration email
TRAEFIK_VERSION_TAG=v4
TRAEFIK_DASHBOARD_HOST_RULE=Host(`traefik2.aaronsoft.de`) || Host(`traefik2.get-orga-niced.de`) 
TRAEFIK_DASHBOARD_CREDENTIALS=admin:$$apr1$$4vqie50r$$YQAmQdtmz5n9rEALhxJ4l.
TRAEFIK_ACME_EMAIL=your@mail.com

# --- Watchtower (Container Updater) ---
# Version tag
WATCHTOWER_VERSION_TAG=latest
WATCHTOWER_POLL_INTERVAL=900

# --- Web Services ---
# Version tags and host rules for the public-facing static/app websites
WEB_AARONSOFT_VERSION_TAG=latest
WEB_GETORGANICED_VERSION_TAG=latest
WEB_AARONSOFT_HOST_RULE=Host(`www2.aaronsoft.de`)
WEB_GETORGANICED_HOST_RULE=Host(`www2.get-orga-niced.de`)

# --- Administration Tools ---
# Routing for the database management interface
ADMINER_VERSION_TAG=latest
ADMINER_HOST_RULE=Host(`admin2.aaronsoft.de`) || Host(`admin2.get-orga-niced.de`)

# --- Roundcube Webmail ---
# Routing, security keys, OAuth2 credentials for the mail client and database
ROUNDCUBE_VERSION_TAG=1.6-nonroot
ROUNDCUBE_HOST_RULE=Host(`mail2.aaronsoft.de`) || Host(`mail2.get-orga-niced.de`)
ROUNDCUBE_DEFAULT_HOST=ssl://mail.gandi.net
ROUNDCUBE_DEFAULT_PORT=993
ROUNDCUBE_SMTP_SERVER=ssl://mail.gandi.net
ROUNDCUBE_SMTP_PORT=465
ROUNDCUBE_MYSQL_DATABASE=roundcubemail
ROUNDCUBE_MYSQL_USER=roundcube
ROUNDCUBE_MYSQL_PASSWORD=roundcube_pass
ROUNDCUBE_GOOGLE_CLIENT_ID=your_google_client_id
ROUNDCUBE_GOOGLE_CLIENT_SECRET=your_google_client_secret