# --- System & Identity ---
# Timezone and user/group IDs to ensure proper file permissions and log timestamps
TZ=Europe/Berlin
PUID=1000
GUID=1000
SOCKET_GID=987

# --- DNS & Domain Management ---
# API token for Let's Encrypt DNS challenges (e.g., for Gandi LiveDNS)
GANDIV5_PERSONAL_ACCESS_TOKEN=your_token_here

# --- Traefik Reverse Proxy ---
# Let's Encrypt registration email and Traefik dashboard configuration
TRAEFIK_ACME_EMAIL=your@mail.com
TRAEFIK_DASHBOARD_HOST_RULE=Host(`traefik2.aaronsoft.de`) || Host(`traefik2.get-orga-niced.de`) 
TRAEFIK_DASHBOARD_CREDENTIALS=admin:admin

# --- Database (MariaDB/MySQL) ---
# Credentials for the internal database network
MYSQL_ROOT_PASSWORD=super_secure_root_pass

# --- Web Services (Routing) ---
# Host rules for the public-facing static/app websites
WEB_AARONSOFT_HOST_RULE=Host(`www2.aaronsoft.de`)
WEB_GETORGANICED_HOST_RULE=Host(`www2.get-orga-niced.de`)

# --- Administration Tools ---
# Routing for the database management interface
ADMINER_HOST_RULE=Host(`admin2.aaronsoft.de`) || Host(`admin2.get-orga-niced.de`)

# --- Roundcube Webmail ---
# Routing, security keys, OAuth2 credentials for the mail client and database
ROUNDCUBEMAIL_HOST_RULE=Host(`mail.aaronsoft.de`) || Host(`mail.get-orga-niced.de`)
ROUNDCUBEMAIL_DES_KEY=some_random_string_for_security
ROUNDCUBEMAIL_GOOGLE_CLIENT_ID=your_google_client_id
ROUNDCUBEMAIL_GOOGLE_CLIENT_SECRET=your_google_client_secret
ROUNDCUBEMAIL_MYSQL_DATABASE=roundcubemail
ROUNDCUBEMAIL_MYSQL_USER=roundcube
ROUNDCUBEMAIL_MYSQL_PASSWORD=roundcube_pass