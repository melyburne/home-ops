###############################################################################
# SECTION 1: SYSTEM & INFRASTRUCTURE
# Core identity, host variables, and automated maintenance tasks.
###############################################################################

# --- System & Identity & Global Secrets ---
# User/Group IDs, API token for Let's Encrypt DNS challenges
PUID=1000
GUID=1000
DOCKER_SOCKET_GID=987
GANDIV5_PERSONAL_ACCESS_TOKEN="your_token_here"

# --- Templates ---
BUSYBOX_DOCKER_TAG=1.36

# --- Watchtower (Container Updater) ---
WATCHTOWER_DOCKER_TAG=latest
WATCHTOWER_POLL_INTERVAL=900


###############################################################################
# SECTION 2: NETWORKING & SECURITY
# Reverse proxy, SSL certificates, and dynamic DNS management.
###############################################################################

# --- Traefik Reverse Proxy ---
TRAEFIK_DOCKER_TAG=v3
TRAEFIK_DASHBOARD_HOST_RULE="Host(`traefik2.aaronsoft.de`) || Host(`traefik2.get-orga-niced.de`)"
TRAEFIK_DASHBOARD_CREDENTIALS="admin:$$apr1$$4vqie50r$$YQAmQdtmz5n9rEALhxJ4l."
TRAEFIK_ACME_EMAIL="your@mail.com"

# --- DDNS Updater ---
DDNS_UPDATER_DOCKER_TAG=latest


###############################################################################
# SECTION 3: DATABASES & DATA MANAGEMENT
# Relational databases and their web-based management tools.
###############################################################################

# --- MariaDB ---
MARIADB_DOCKER_TAG=11.4
MARIADB_ROOT_PASSWORD="super_secure_root_pass"

# --- Administration Tools (Adminer) ---
ADMINER_DOCKER_TAG=latest
ADMINER_HOST_RULE="Host(`admin2.aaronsoft.de`) || Host(`admin2.get-orga-niced.de`)"


###############################################################################
# SECTION 4: WEB APPLICATIONS & SERVICES
# End-user facing standalone applications and static websites.
###############################################################################

# --- Web Services (Static Sites) ---
WEB_AARONSOFT_DOCKER_TAG=latest
WEB_AARONSOFT_HOST_RULE="Host(`www2.aaronsoft.de`)"

WEB_GETORGANICED_DOCKER_TAG=latest
WEB_GETORGANICED_HOST_RULE="Host(`www2.get-orga-niced.de`)"

# --- Roundcube Webmail ---
ROUNDCUBE_DOCKER_TAG=1.6-nonroot
ROUNDCUBE_HOST_RULE="Host(`mail2.aaronsoft.de`) || Host(`mail2.get-orga-niced.de`)"
ROUNDCUBE_DB_NAME=roundcubemail
ROUNDCUBE_DB_USER=roundcube
ROUNDCUBE_DB_PASSWORD="roundcube_pass"
ROUNDCUBE_IMAP_HOST="ssl://mail.gandi.net"
ROUNDCUBE_IMAP_PORT=993
ROUNDCUBE_SMTP_SERVER="ssl://mail.gandi.net"
