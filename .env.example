###############################################################################
# HOME-OPS ENVIRONMENT CONFIGURATION
#
# Instructions:
# - Uncommented lines are REQUIRED and must be filled out.
# - Commented lines (#) show the default values used by the stack.
#   Uncomment them ONLY if you need to override the default behavior.
###############################################################################

###############################################################################
# SECTION 1: SYSTEM & INFRASTRUCTURE
###############################################################################

# --- Global Secrets ---
GANDIV5_PERSONAL_ACCESS_TOKEN="your_access_token"

# --- System & Identity ---
# User/Group IDs for container permissions
# PUID=1000
# GUID=1000
# DOCKER_SOCKET_GID=987

# --- Templates & Core Image Tags ---
# BUSYBOX_DOCKER_TAG=latest
# ALPINE_DOCKER_TAG=latest

# --- Watchtower (Container Updater) ---
# WATCHTOWER_DOCKER_TAG=latest
# WATCHTOWER_POLL_INTERVAL=900


###############################################################################
# SECTION 2: NETWORKING & SECURITY
###############################################################################

# --- Traefik Reverse Proxy ---
TRAEFIK_DASHBOARD_CREDENTIALS="admin:$$apr1$$4vqie50r$$YQAmQdtmz5n9rEALhxJ4l."
TRAEFIK_ACME_EMAIL="your@mail.com"

# TRAEFIK_DOCKER_TAG=latest
# TRAEFIK_DASHBOARD_HOST_RULE="Host(`traefik.localhost`)"

# --- DDNS Updater ---
# DDNS_UPDATER_DOCKER_TAG=latest


###############################################################################
# SECTION 3: DATABASES & DATA MANAGEMENT
###############################################################################

# --- MariaDB ---
# MARIADB_DOCKER_TAG=latest
MARIADB_ROOT_PASSWORD="your_mariadb_password"

# --- Administration Tools (Adminer) ---
# ADMINER_DOCKER_TAG=latest
# ADMINER_HOST_RULE="Host(`adminer.localhost`)"


###############################################################################
# SECTION 4: WEB APPLICATIONS & SERVICES
###############################################################################

# --- Roundcube Webmail ---
ROUNDCUBE_DB_PASSWORD="your_roundcube_password"
ROUNDCUBE_IMAP_HOST="ssl://your.mail.provider"
ROUNDCUBE_SMTP_SERVER="ssl://your.mail.provider"

# ROUNDCUBE_DOCKER_TAG=latest-nonroot
# ROUNDCUBE_HOST_RULE="Host(`mail.localhost`)"
# ROUNDCUBE_DB_NAME=roundcubemail
# ROUNDCUBE_DB_USER=roundcube
# ROUNDCUBE_IMAP_PORT=993
# ROUNDCUBE_SMTP_PORT=465

# --- Web Services (Static Sites) ---
# WEB_AARONSOFT_DOCKER_TAG=latest
# WEB_AARONSOFT_HOST_RULE="Host(`aaronsoft.localhost`)"

# WEB_GETORGANICED_DOCKER_TAG=latest
# WEB_GETORGANICED_HOST_RULE="Host(`organiced.localhost`)"


###############################################################################
# SECTION 5: OWNCLOUD COLLABORATION SUITE
###############################################################################

# --- Owncloud Infinity Scale (oCIS) ---
OCIS_SMTP_HOST="smtp.example.com"
OCIS_SMTP_SENDER="oCIS noreply <noreply@aaronsoft.de>"
OCIS_SMTP_USERNAME="your_smtp_user"
OCIS_SMTP_PASSWORD="your_smtp_password"

# OCIS_DOCKER_TAG=latest
# OCIS_DOMAIN="ocis.localhost"
# OCIS_CONFIG_DIR="./data/config/"
# OCIS_DATA_DIR="./data/data/"
# OCIS_SMTP_PORT=465
# OCIS_SMTP_AUTHENTICATION="login"

# --- OnlyOffice (oCIS Document Server) ---
OCIS_ONLYOFFICE_DB_PASSWORD="your_onlyoffice_password"
OCIS_ONLYOFFICE_JWT_SECRET="your_jwt_secret"

# OCIS_ONLYOFFICE_DOCKER_TAG=latest
# OCIS_ONLYOFFICE_DOMAIN="onlyoffice.localhost"
# OCIS_ONLYOFFICE_DB_NAME=onlyoffice
# OCIS_ONLYOFFICE_DB_USER=onlyoffice

# --- oCIS Extensions ---
# OCIS_EXT_3D_VIEWER_DOCKER_TAG=0.1.0
# OCIS_EXT_ADV_SEARCH_DOCKER_TAG=latest
# OCIS_EXT_DRAWIO_DOCKER_TAG=latest
# OCIS_EXT_JSON_VIEWER_DOCKER_TAG=latest
# OCIS_EXT_PHOTO_ADDON_DOCKER_TAG=latest
# OCIS_EXT_UNZIP_DOCKER_TAG=latest
# OCIS_EXT_APP_TOKENS_DOCKER_TAG=latest
# OCIS_EXT_EXCALIDRAW_DOCKER_TAG=latest