{
  "services": {
    "CoAuthoring": {
      "ipfilter": {
        "rules": [
          {
            "address": "collaboration-oo",
            "allowed": true
          },
          {
            "address": "*",
            "allowed": false
          }
        ],
        "useforrequest": false,
        "errorcode": 403
      }
    }
  },
  "FileConverter": {
		"converter": {
			"inputLimits": [
				{
				"type": "docx;dotx;docm;dotm",
				"zip": {
					"uncompressed": "1GB",
					"template": "*.xml"
				}
				},
				{
				"type": "xlsx;xltx;xlsm;xltm",
				"zip": {
					"uncompressed": "1GB",
					"template": "*.xml"
				}
				},
				{
				"type": "pptx;ppsx;potx;pptm;ppsm;potm",
				"zip": {
					"uncompressed": "1GB",
					"template": "*.xml"
				}
				}
			]
		}
	}
}